		<ConceptDefinition
			conceptKind=$Semantic
			description="Finds a root of a function within a bracket using bisection or Brent's method."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:FindRootBracketed
			key=~findRootBracketed
			name="FindRootBracketed"
		>
