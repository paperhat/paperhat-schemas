				<RequiresChildConcept conceptSelector="LowerBound" max=1 min=1 />

				<RequiresChildConcept conceptSelector="UpperBound" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Finds a local minimum of a function within a bracket."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:FindMinimum
