	<ConstraintDefinitions>

		[GROUP: Matched Pairs Constraints - Arithmetic]

		<ConstraintDefinition
			description="Add must use either Augend/Addend OR X/Y, but not mix them."
			id=urn:paperhat:behavior:constraint:add-matched-pairs
			title="Add requires matched argument pairs"
		>
			<Targets>
				<TargetConcept conceptSelector="Add" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="Augend" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="X" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="X" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Augend" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Addend" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			description="Subtract must use either Minuend/Subtrahend OR X/Y, but not mix them."
			id=urn:paperhat:behavior:constraint:subtract-matched-pairs
			title="Subtract requires matched argument pairs"
		>
			<Targets>
				<TargetConcept conceptSelector="Subtract" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="Minuend" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Subtrahend" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="X" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="X" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Minuend" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Subtrahend" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			description="Multiply must use either Multiplicand/Multiplier OR X/Y, but not mix them."
			id=urn:paperhat:behavior:constraint:multiply-matched-pairs
			title="Multiply requires matched argument pairs"
		>
			<Targets>
				<TargetConcept conceptSelector="Multiply" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="Multiplicand" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="X" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="X" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Multiplicand" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Multiplier" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			description="DivideBy must use either Dividend/Divisor OR X/Y, but not mix them."
			id=urn:paperhat:behavior:constraint:divide-matched-pairs
			title="DivideBy requires matched argument pairs"
		>
			<Targets>
				<TargetConcept conceptSelector="DivideBy" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="Dividend" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Divisor" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="X" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="X" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Dividend" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Divisor" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			description="Power must use either Base/Exponent OR X/Y, but not mix them."
			id=urn:paperhat:behavior:constraint:power-matched-pairs
			title="Power requires matched argument pairs"
		>
			<Targets>
				<TargetConcept conceptSelector="Power" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="Base" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Exponent" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="X" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="X" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Base" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Exponent" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		[END: Matched Pairs Constraints - Arithmetic]

		[GROUP: Matched Pairs Constraints - Comparison]

		<ConstraintDefinition
			description="Comparison operators must use either Referent/Comparator OR X/Y, but not mix them."
			id=urn:paperhat:behavior:constraint:comparison-matched-pairs
			title="Comparison operators require matched argument pairs"
		>
			<Targets>
				<TargetConcept conceptSelector="IsEqualTo" />

				<TargetConcept conceptSelector="IsNotEqualTo" />

				<TargetConcept conceptSelector="IsLessThan" />

				<TargetConcept conceptSelector="IsGreaterThan" />

				<TargetConcept conceptSelector="IsLessThanOrEqualTo" />

				<TargetConcept conceptSelector="IsGreaterThanOrEqualTo" />

				<TargetConcept conceptSelector="IsAfter" />

				<TargetConcept conceptSelector="IsBefore" />

				<TargetConcept conceptSelector="IsSameInstant" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="Referent" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Comparator" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="X" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="X" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Y" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Referent" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Comparator" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		[END: Matched Pairs Constraints - Comparison]

	</ConstraintDefinitions>
</Schema>
