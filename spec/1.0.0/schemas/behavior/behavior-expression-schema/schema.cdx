			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Geometry - 2D]

		[GROUP: Geometry - 3D]

		<ConceptDefinition
			conceptKind=$Semantic
			description="Computes the Euclidean distance between two points in 3D space."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:DistanceBetweenPoints3D
			key=~distanceBetweenPoints3D
			name="DistanceBetweenPoints3D"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Point1" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Point2" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Computes the midpoint between two points in 3D space."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:MidpointBetweenPoints3D
			key=~midpointBetweenPoints3D
			name="MidpointBetweenPoints3D"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Point1" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Point2" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Rotates a point around an arbitrary axis in 3D space."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:RotatePoint3DAroundAxis
			key=~rotatePoint3DAroundAxis
			name="RotatePoint3DAroundAxis"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Point" max=1 min=1 />

				<RequiresChildConcept conceptSelector="AxisOrigin" max=1 min=1 />

				<RequiresChildConcept conceptSelector="AxisDirection" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Angle" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Computes the volume of a tetrahedron given four vertices in 3D space."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:TetrahedronVolume
			key=~tetrahedronVolume
			name="TetrahedronVolume"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Point1" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Point2" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Point3" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Point4" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Tests whether a point lies inside a sphere defined by center and radius."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:IsPointInSphere
			key=~isPointInSphere
			name="IsPointInSphere"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Point" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Center" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Radius" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Tests whether a point lies inside an axis-aligned box in 3D space."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:IsPointInBox
			key=~isPointInBox
			name="IsPointInBox"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Point" max=1 min=1 />

				<RequiresChildConcept conceptSelector="MinCorner" max=1 min=1 />

				<RequiresChildConcept conceptSelector="MaxCorner" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="Wrapper for the fourth point in geometry operations."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Point4
			key=~point4
			name="Point4"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="Wrapper for the origin point of a rotation axis."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:AxisOrigin
			key=~axisOrigin
			name="AxisOrigin"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="Wrapper for the direction vector of a rotation axis."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:AxisDirection
			key=~axisDirection
			name="AxisDirection"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Geometry - 3D]

		[GROUP: Angle Normalization]

		<ConceptDefinition
			conceptKind=$Semantic
			description="Normalizes an angle in radians to the range [0, 2π)."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:NormalizeAngleRadians
			key=~normalizeAngleRadians
			name="NormalizeAngleRadians"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Normalizes an angle in radians to the range [-π, π)."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:NormalizeAngleRadiansSigned
			key=~normalizeAngleRadiansSigned
			name="NormalizeAngleRadiansSigned"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Normalizes an angle in degrees to the range [0, 360)."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:NormalizeAngleDegrees
			key=~normalizeAngleDegrees
			name="NormalizeAngleDegrees"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Normalizes an angle in degrees to the range [-180, 180)."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:NormalizeAngleDegreesSigned
			key=~normalizeAngleDegreesSigned
			name="NormalizeAngleDegreesSigned"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Computes the shortest signed difference between two angles (in radians)."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:ShortestAngleDifference
			key=~shortestAngleDifference
			name="ShortestAngleDifference"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="X" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Y" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		[END: Angle Normalization]

	</ConceptDefinitions>

