				<RequiresChildConcept conceptSelector="LowerBound" max=1 min=1 />

				<RequiresChildConcept conceptSelector="UpperBound" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
