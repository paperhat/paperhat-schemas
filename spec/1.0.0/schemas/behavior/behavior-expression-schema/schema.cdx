			key=~numericalDerivative
			name="NumericalDerivative"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Function" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Point" max=1 min=1 />
			</ChildRules>
