<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="Schema for authoring Behavior expressions in Codex surface form."
	id=urn:paperhat:behavior:1.0.0
	namespace="behavior"
	title="Behavior Expression Schema"
	version="1.0.0"
	versionScheme=$Semver
>
	<EnumeratedValueSets>
		<EnumeratedValueSet
			id=urn:paperhat:behavior:enum:ArgumentPosition
			key=~argumentPosition
			name="ArgumentPosition"
		>
			<Member description="Generic first operand position." label="X" value="X" />

			<Member description="Generic second operand position." label="Y" value="Y" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=urn:paperhat:behavior:enum:RoundingMode
			key=~roundingMode
			name="RoundingMode"
		>
			<Member value="TowardZero" />

			<Member value="TowardPositiveInfinity" />

			<Member value="TowardNegativeInfinity" />

			<Member value="TiesToEven" />

			<Member value="TiesAwayFromZero" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=urn:paperhat:behavior:enum:DisambiguationMode
			key=~disambiguationMode
			name="DisambiguationMode"
		>
			<Member description="Use earlier of two possible times during DST transition." value="Earlier" />

			<Member description="Use later of two possible times during DST transition." value="Later" />

			<Member description="Use behavior compatible with ECMAScript Date semantics." value="Compatible" />

			<Member description="Return Invalid for ambiguous times." value="Reject" />
		</EnumeratedValueSet>
	</EnumeratedValueSets>

	<ConceptDefinitions>

		[GROUP: Expression Containers]

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Calculation
			key=~calculation
			name="Calculation"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Validation
			key=~validation
			name="Validation"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Expression Containers]

		[GROUP: Core Expression Nodes]

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Argument
			key=~argument
			name="Argument"
		>
			<TraitRules>
				<AllowsTrait name="index" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Variable
			key=~variable
			name="Variable"
		>
			<TraitRules>
				<RequiresTrait name="name" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Constant
			key=~constant
			name="Constant"
		>
			<ContentRules>
				<AllowsContent whitespaceMode=$Flow />
			</ContentRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:FieldStep
			key=~fieldStep
			name="FieldStep"
		>
			<TraitRules>
				<RequiresTrait name="name" />
			</TraitRules>

			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Index
			key=~index
			name="Index"
		>
			<ChildRules>
				<RequiresChildConcept conceptSelector="Source" max=1 min=1 />

				<RequiresChildConcept conceptSelector="Position" max=1 min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Source
			key=~source
			name="Source"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Position
			key=~position
			name="Position"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Absent
			key=~absent
			name="Absent"
		/>

		[END: Core Expression Nodes]

		[GROUP: Context and Input Nodes]

		<ConceptDefinition
			conceptKind=$ValueLike
			description="References the input value being validated in a ValueShape context."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Input
			key=~input
			name="Input"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			description="References the current entity node in an EntityShape context."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:ThisNode
			key=~thisNode
			name="ThisNode"
		/>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Reads a trait value from the current node or a specified node."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Field
			key=~field
			name="Field"
		>
			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="for" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			description="References the current element during collection iteration."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Element
			key=~element
			name="Element"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			description="References a named parameter for parameterized behaviors."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Parameter
			key=~parameter
			name="Parameter"
		>
			<TraitRules>
				<RequiresTrait name="name" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			description="A constant literal value."
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Literal
			key=~literal
			name="Literal"
		>
			<TraitRules>
				<RequiresTrait name="value" />
			</TraitRules>
		</ConceptDefinition>

		[END: Context and Input Nodes]

		[GROUP: Generic Argument Wrappers]

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:X
			key=~x
			name="X"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Y
			key=~y
			name="Y"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Generic Argument Wrappers]

		[GROUP: Semantic Argument Wrappers - Arithmetic]

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Augend
			key=~augend
			name="Augend"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Addend
			key=~addend
			name="Addend"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Minuend
			key=~minuend
			name="Minuend"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Subtrahend
			key=~subtrahend
			name="Subtrahend"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Multiplicand
			key=~multiplicand
			name="Multiplicand"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Multiplier
			key=~multiplier
			name="Multiplier"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Dividend
			key=~dividend
			name="Dividend"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Divisor
			key=~divisor
			name="Divisor"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Base
			key=~base
			name="Base"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Exponent
			key=~exponent
			name="Exponent"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Semantic Argument Wrappers - Arithmetic]

		[GROUP: Semantic Argument Wrappers - Comparison]

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Referent
			key=~referent
			name="Referent"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Comparator
			key=~comparator
			name="Comparator"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Semantic Argument Wrappers - Comparison]

		[GROUP: Semantic Argument Wrappers - Logical]

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Condition
			key=~condition
			name="Condition"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Then
			key=~then
			name="Then"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Else
			key=~else
			name="Else"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Operand
			key=~operand
			name="Operand"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Semantic Argument Wrappers - Logical]

		[GROUP: Mathematical Constants]

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Pi
			key=~pi
			name="Pi"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Tau
			key=~tau
			name="Tau"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:EulerNumber
			key=~eulerNumber
			name="EulerNumber"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:GoldenRatio
			key=~goldenRatio
			name="GoldenRatio"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:ImaginaryUnit
			key=~imaginaryUnit
			name="ImaginaryUnit"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:PositiveInfinity
			key=~positiveInfinity
			name="PositiveInfinity"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:NegativeInfinity
			key=~negativeInfinity
			name="NegativeInfinity"
		/>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:NegativeZero
			key=~negativeZero
			name="NegativeZero"
		/>

		[END: Mathematical Constants]

		[GROUP: Complex Number Operations]

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:MakeComplex
			key=~makeComplex
			name="MakeComplex"
		>
			<TraitRules>
				<RequiresTrait name="real" />

				<RequiresTrait name="imaginary" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:MakeImaginary
			key=~makeImaginary
			name="MakeImaginary"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:MakeComplexFromPolar
			key=~makeComplexFromPolar
			name="MakeComplexFromPolar"
		>
			<TraitRules>
				<RequiresTrait name="magnitude" />

				<RequiresTrait name="phase" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:RealPart
			key=~realPart
			name="RealPart"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:ImaginaryPart
			key=~imaginaryPart
			name="ImaginaryPart"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Conjugate
			key=~conjugate
			name="Conjugate"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Magnitude
			key=~magnitude
			name="Magnitude"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Phase
			key=~phase
			name="Phase"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		[END: Complex Number Operations]

		[GROUP: Basic Arithmetic Operators]

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Add
			key=~add
			name="Add"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Augend" max=1 />

				<AllowsChildConcept conceptSelector="Addend" />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Subtract
			key=~subtract
			name="Subtract"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Minuend" max=1 />

				<AllowsChildConcept conceptSelector="Subtrahend" max=1 />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Multiply
			key=~multiply
			name="Multiply"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Multiplicand" max=1 />

				<AllowsChildConcept conceptSelector="Multiplier" />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:DivideBy
			key=~divideBy
			name="DivideBy"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Dividend" max=1 />

				<AllowsChildConcept conceptSelector="Divisor" max=1 />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Negate
			key=~negate
			name="Negate"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Operand" max=1 />

				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Reciprocal
			key=~reciprocal
			name="Reciprocal"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Operand" max=1 />

				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Power
			key=~power
			name="Power"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Base" max=1 />

				<AllowsChildConcept conceptSelector="Exponent" max=1 />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		[END: Basic Arithmetic Operators]

		[GROUP: Integer Arithmetic Operators]

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:QuotientTowardZero
			key=~quotientTowardZero
			name="QuotientTowardZero"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Dividend" max=1 />

				<AllowsChildConcept conceptSelector="Divisor" max=1 />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:QuotientTowardNegativeInfinity
			key=~quotientTowardNegativeInfinity
			name="QuotientTowardNegativeInfinity"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Dividend" max=1 />

				<AllowsChildConcept conceptSelector="Divisor" max=1 />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Remainder
			key=~remainder
			name="Remainder"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Dividend" max=1 />

				<AllowsChildConcept conceptSelector="Divisor" max=1 />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Modulus
			key=~modulus
			name="Modulus"
		>
			<ChildRules>
				<AllowsChildConcept conceptSelector="Dividend" max=1 />

				<AllowsChildConcept conceptSelector="Divisor" max=1 />

				<AllowsChildConcept conceptSelector="X" max=1 />

				<AllowsChildConcept conceptSelector="Y" max=1 />
			</ChildRules>
		</ConceptDefinition>

		[END: Integer Arithmetic Operators]

		[GROUP: Value Operations]

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:AbsoluteValue
			key=~absoluteValue
			name="AbsoluteValue"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Sign
			key=~sign
			name="Sign"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Minimum
			key=~minimum
			name="Minimum"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=urn:paperhat:behavior:concept:Maximum
			key=~maximum
			name="Maximum"
		>
			<ChildRules>
				<AllowsLocalChildren />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
