<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description=`
		Hardened Agent Governance Schema.
		
		Evaluation Rules:
		1. Highest precedence wins.
		2. OutOfScope shadows InScope on precedence tie.
		3. No match defaults to OutOfScope.
		4. Root, Literal, and Prefix are anchored to the directory containing the defining .agents file.
		5. Glob is the only mode allowed to express anywhere or recursive matches (**).
	`
	id=paperhat:domain:agent
	namespace="agent"
	title="Agent Schema"
	version="1.0.0"
	versionScheme=$SemanticVersion
>
	<SchemaImports>
		<SchemaImport namespace="text" reference=urn:cdx:sha256:56710936ccb873445f40c284809a6753878a18a19c1a0a56e43de8c8075ec4fc />
		<SchemaImport namespace="grammar" reference=urn:cdx:sha256:c2b442c61ab57e513cc69fddd3141d58b1ee829561301f5835e246875476996d />
	</SchemaImports>

	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:AgentFile
			name="AgentFile"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />
				<RequiresTrait name="targetFileKind" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="AgentCapability" />
				<AllowsChildConcept conceptSelector="VerificationGate" />
				<AllowsChildConcept conceptSelector="AgentPathFence" />
				<AllowsChildConcept conceptSelector="AgentSection" />
				<AllowsChildConcept conceptSelector="ProjectDescription" />
				<AllowsChildConcept conceptSelector="ArchitectureOverview" />
				<AllowsChildConcept conceptSelector="OutputFormat" />
				<AllowsChildConcept conceptSelector="SecurityRequirements" />
				<AllowsChildConcept conceptSelector="CodingConventions" />
				<AllowsChildConcept conceptSelector="TestingFramework" />
				<AllowsChildConcept conceptSelector="AgentRole" />
				<AllowsChildConcept conceptSelector="TechStack" />
				<AllowsChildConcept conceptSelector="CommandSet" />
				<AllowsChildConcept conceptSelector="DirectoryLayout" />
				<AllowsChildConcept conceptSelector="Workflow" />
				<AllowsChildConcept conceptSelector="Glossary" />
				<AllowsChildConcept conceptSelector="McpConfiguration" />
				<AllowsChildConcept conceptSelector="CodeBlock" />
				<AllowsChildConcept conceptSelector="MermaidDiagram" />
				<AllowsChildConcept conceptSelector="grammar:Grammar" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:AgentCapability
			name="AgentCapability"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="toolName" />
				<RequiresTrait name="accessLevel" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:VerificationGate
			name="VerificationGate"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="checkCommand" />
				<RequiresTrait name="failurePolicy" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:AgentPathFence
			name="AgentPathFence"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="pathKind" />
				<RequiresTrait name="precedence" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="AgentPath" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:AgentPath
			name="AgentPath"
		>
			<ContentRules>
				<RequiresContent whitespaceMode=$Flow />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="matchMode" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:AgentSection
			name="AgentSection"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="key" />
				<RequiresTrait name="title" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="text:Paragraph" />
				<RequiresChildConcept conceptSelector="AgentRequirement" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:AgentRequirement
			name="AgentRequirement"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="key" />
				<RequiresTrait name="modality" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="RequiredClause" max=1 min=1 />
				<RequiresChildConcept conceptSelector="ForbiddenClause" max=1 min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:ProjectDescription
			name="ProjectDescription"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="text:Paragraph" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:ArchitectureOverview
			name="ArchitectureOverview"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="text:Paragraph" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:OutputFormat
			name="OutputFormat"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="text:Paragraph" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:SecurityRequirements
			name="SecurityRequirements"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="AgentRequirement" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:CodingConventions
			name="CodingConventions"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="text:Paragraph" />
				<RequiresChildConcept conceptSelector="AgentRequirement" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:TestingFramework
			name="TestingFramework"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="text:Paragraph" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:AgentRole
			name="AgentRole"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="role" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:TechStack
			name="TechStack"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="Technology" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:Technology
			name="Technology"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />
				<RequiresTrait name="kind" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:CommandSet
			name="CommandSet"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="kind" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="Command" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:Command
			name="Command"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="invocation" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:DirectoryLayout
			name="DirectoryLayout"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="DirectoryEntry" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:DirectoryEntry
			name="DirectoryEntry"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />
				<RequiresTrait name="kind" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:Workflow
			name="Workflow"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="WorkflowStep" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:WorkflowStep
			name="WorkflowStep"
		>
			<ContentRules>
				<RequiresContent whitespaceMode=$Flow />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="order" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:Glossary
			name="Glossary"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="GlossaryEntry" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:GlossaryEntry
			name="GlossaryEntry"
		>
			<ContentRules>
				<RequiresContent whitespaceMode=$Flow />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="term" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:McpConfiguration
			name="McpConfiguration"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="McpServer" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:agent:McpServer
			name="McpServer"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />
				<RequiresTrait name="serverType" />
				<RequiresTrait name="scope" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:CodeBlock
			name="CodeBlock"
		>
			<ContentRules>
				<RequiresContent whitespaceMode=$Flow />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="language" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$ValueLike
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:MermaidDiagram
			name="MermaidDiagram"
		>
			<ContentRules>
				<RequiresContent whitespaceMode=$Flow />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="diagramType" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:RequiredClause
			name="RequiredClause"
		>
			<ContentRules>
				<RequiresContent whitespaceMode=$Flow />
			</ContentRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:agent:ForbiddenClause
			name="ForbiddenClause"
		>
			<ContentRules>
				<RequiresContent whitespaceMode=$Flow />
			</ContentRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:name
			name="name"
		/>

		<TraitDefinition
			defaultValueType=$LookupToken
			id=paperhat:domain:agent:trait:key
			name="key"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:title
			name="title"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:toolName
			name="toolName"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:role
			name="role"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:kind
			name="kind"
		>
			<AllowedValues>
				<EnumeratedConstraint set="TechnologyKind" />
				<EnumeratedConstraint set="CommandKind" />
				<EnumeratedConstraint set="DirectoryEntryKind" />
			</AllowedValues>
		</TraitDefinition>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:version
			name="version"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:invocation
			name="invocation"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:description
			name="description"
		/>

		<TraitDefinition
			defaultValueType=$Integer
			id=paperhat:domain:agent:trait:order
			name="order"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:term
			name="term"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:serverType
			name="serverType"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:scope
			name="scope"
		>
			<AllowedValues>
				<EnumeratedConstraint set="McpServerScope" />
			</AllowedValues>
		</TraitDefinition>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:language
			name="language"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:diagramType
			name="diagramType"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:agent:trait:checkCommand
			name="checkCommand"
		/>

		<TraitDefinition
			defaultValueType=$Integer
			id=paperhat:domain:agent:trait:precedence
			name="precedence"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:targetFileKind
			name="targetFileKind"
		>
			<AllowedValues>
				<EnumeratedConstraint set="TargetFileKind" />
			</AllowedValues>
		</TraitDefinition>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:pathKind
			name="pathKind"
		>
			<AllowedValues>
				<EnumeratedConstraint set="PathFenceKind" />
			</AllowedValues>
		</TraitDefinition>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:matchMode
			name="matchMode"
		>
			<AllowedValues>
				<EnumeratedConstraint set="PathMatchMode" />
			</AllowedValues>
		</TraitDefinition>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:accessLevel
			name="accessLevel"
		>
			<AllowedValues>
				<EnumeratedConstraint set="AccessLevel" />
			</AllowedValues>
		</TraitDefinition>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:failurePolicy
			name="failurePolicy"
		>
			<AllowedValues>
				<EnumeratedConstraint set="FailurePolicy" />
			</AllowedValues>
		</TraitDefinition>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:agent:trait:modality
			name="modality"
		>
			<AllowedValues>
				<EnumeratedConstraint set="RequirementModality" />
			</AllowedValues>
		</TraitDefinition>
	</TraitDefinitions>

	<EnumeratedValueSets>
		<EnumeratedValueSet
			id=paperhat:domain:agent:set:TargetFileKind
			name="TargetFileKind"
		>
			<Member value="AgentsMd" />
			<Member value="ClaudeMd" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:PathFenceKind
			name="PathFenceKind"
		>
			<Member value="InScope" />
			<Member value="OutOfScope" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:PathMatchMode
			name="PathMatchMode"
		>
			<Member value="Root" />
			<Member value="Literal" />
			<Member value="Prefix" />
			<Member value="Glob" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:AccessLevel
			name="AccessLevel"
		>
			<Member value="Read" />
			<Member value="Write" />
			<Member value="Execute" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:FailurePolicy
			name="FailurePolicy"
		>
			<Member value="Block" />
			<Member value="Warn" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:RequirementModality
			name="RequirementModality"
		>
			<Member value="Must" />
			<Member value="MustNot" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:DirectoryEntryKind
			name="DirectoryEntryKind"
		>
			<Member value="Directory" />
			<Member value="File" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:TechnologyKind
			name="TechnologyKind"
		>
			<Member value="Language" />
			<Member value="Framework" />
			<Member value="Runtime" />
			<Member value="Tool" />
			<Member value="Library" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:CommandKind
			name="CommandKind"
		>
			<Member value="Build" />
			<Member value="Test" />
			<Member value="Validate" />
			<Member value="Run" />
			<Member value="Lint" />
			<Member value="Forbidden" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:agent:set:McpServerScope
			name="McpServerScope"
		>
			<Member value="Project" />
			<Member value="User" />
		</EnumeratedValueSet>
	</EnumeratedValueSets>

	<ConstraintDefinitions>
		<ConstraintDefinition
			id=paperhat:domain:agent:path-normalization
			title="Path Normalization Rules"
		>
			<Targets>
				<TargetConcept conceptSelector="AgentPath" />
			</Targets>
			<Rule>
				<AllOf>
					<Rule>
						<ValueMatchesPattern pattern="^[^/]" />
					</Rule>
					<Rule>
						<ValueMatchesPattern pattern="^(?!\.\./)" />
					</Rule>
					<Rule>
						<ValueMatchesPattern pattern="^(?!.*//)" />
					</Rule>
				</AllOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:agent:match-mode-root
			title="Root Match Mode Rules"
		>
			<Targets>
				<TargetConcept conceptSelector="AgentPath" />
			</Targets>
			<Rule>
				<ConditionalConstraint>
					<When>
						<Rule>
							<TraitEquals trait="matchMode" value=$Root />
						</Rule>
					</When>
					<Then>
						<Rule>
							<ValueMatchesPattern pattern="^\.$" />
						</Rule>
					</Then>
				</ConditionalConstraint>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:agent:match-mode-literal
			title="Literal Match Mode Rules"
		>
			<Targets>
				<TargetConcept conceptSelector="AgentPath" />
			</Targets>
			<Rule>
				<ConditionalConstraint>
					<When>
						<Rule>
							<TraitEquals trait="matchMode" value=$Literal />
						</Rule>
					</When>
					<Then>
						<Rule>
							<AllOf>
								<Rule>
									<ValueMatchesPattern pattern="[^/]$" />
								</Rule>
								<Rule>
									<ValueMatchesPattern pattern="^[^*?]*$" />
								</Rule>
							</AllOf>
						</Rule>
					</Then>
				</ConditionalConstraint>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:agent:match-mode-prefix
			title="Prefix Match Mode Rules"
		>
			<Targets>
				<TargetConcept conceptSelector="AgentPath" />
			</Targets>
			<Rule>
				<ConditionalConstraint>
					<When>
						<Rule>
							<TraitEquals trait="matchMode" value=$Prefix />
						</Rule>
					</When>
					<Then>
						<Rule>
							<AllOf>
								<Rule>
									<ValueMatchesPattern pattern="/$" />
								</Rule>
								<Rule>
									<ValueMatchesPattern pattern="^[^*?]*$" />
								</Rule>
							</AllOf>
						</Rule>
					</Then>
				</ConditionalConstraint>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:agent:match-mode-glob
			title="Glob Match Mode Rules"
		>
			<Targets>
				<TargetConcept conceptSelector="AgentPath" />
			</Targets>
			<Rule>
				<ConditionalConstraint>
					<When>
						<Rule>
							<TraitEquals trait="matchMode" value=$Glob />
						</Rule>
					</When>
					<Then>
						<Rule>
							<ValueMatchesPattern pattern="^[a-zA-Z0-9._/*?]*$" />
						</Rule>
					</Then>
				</ConditionalConstraint>
			</Rule>
		</ConstraintDefinition>
	</ConstraintDefinitions>
</Schema>
