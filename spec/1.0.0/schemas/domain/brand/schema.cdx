<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="A named brand identity owned by an organization, such as a product brand, institutional brand, or sub-brand."
	id=paperhat:domain:brand
	namespace="brand"
	title="Brand Schema"
	version="1.0.0"
	versionScheme=$SemanticVersion
>
	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:brand:Brand
			name="Brand"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="brandKind" />

				<AllowsTrait name="owner" />

				<AllowsTrait name="brandStatus" />
			</TraitRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:brand:trait:name
			name="name"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:brand:trait:brandKind
			name="brandKind"
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:brand:trait:owner
			isReferenceTrait=true
			name="owner"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:brand:trait:brandStatus
			name="brandStatus"
		/>
	</TraitDefinitions>
</Schema>
