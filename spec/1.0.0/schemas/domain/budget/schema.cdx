<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description=`
		A named financial plan with categorized line items over a defined period — a project budget,
		departmental budget, or grant budget.
	`
	id=paperhat:domain:budget
	namespace="budget"
	title="Budget Schema"
	version="1.0.0"
	versionScheme=$Semver
>
	<SchemaImports>
		<SchemaImport
			namespace="desc"
			reference=urn:cdx:sha256:a4b26166df726e9c0125b331fc41555d0fd1b455fb93da24b592ba5f2293c641
		/>
	</SchemaImports>

	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:budget:Budget
			name="Budget"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="budgetStatus" />

				<AllowsTrait name="currency" />

				<AllowsTrait name="endDate" />

				<AllowsTrait name="startDate" />

				<AllowsTrait name="totalAmount" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="desc:Description" />
			</ChildRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:budget:trait:budgetStatus
			name="budgetStatus"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:budget:trait:currency
			name="currency"
		/>

		<TraitDefinition
			defaultValueType=$Date
			id=paperhat:domain:budget:trait:endDate
			name="endDate"
		/>

		<TraitDefinition defaultValueType=$Text id=paperhat:domain:budget:trait:name name="name" />

		<TraitDefinition
			defaultValueType=$Date
			id=paperhat:domain:budget:trait:startDate
			name="startDate"
		/>

		<TraitDefinition
			defaultValueType=$Number
			id=paperhat:domain:budget:trait:totalAmount
			name="totalAmount"
		/>
	</TraitDefinitions>
</Schema>
