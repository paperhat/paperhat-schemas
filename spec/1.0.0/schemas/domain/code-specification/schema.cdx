	<EnumeratedValueSets>
		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:TypeRole
			name="TypeRole"
		>
			<Member description="The principal value type of a semantic site." value="ValueType" />

			<Member description="The diagnostic type declared at the specification root." value="DiagnosticType" />

			<Member description="The wrapped payload type of a sum-type variant." value="WrappedType" />

			<Member description="The type produced by a construction operation." value="ProducesType" />

			<Member description="The receiver type of an accessor operation." value="BelongsToType" />

			<Member description="The return type of an accessor operation." value="ReturnType" />

			<Member description="The validated target type of a validation rule." value="AppliesToType" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:Capability
			name="Capability"
		>
			<Member description="Instances are comparable for structural equality." value="Equality" />

			<Member description="Instances produce a deterministic hash value." value="Hashing" />

			<Member description="Instances are duplicatable." value="Cloning" />

			<Member description="Instances have a canonical total ordering." value="CanonicalOrdering" />

			<Member description="Instances have a debug text representation." value="Debugging" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:PrimitiveRepresentationKind
			name="PrimitiveRepresentationKind"
		>
			<Member description="A two-valued logical primitive projected to the host boolean representation." value="Boolean" />

			<Member description="A primitive represented by the host text type." value="Text" />

			<Member description="A signed integral primitive represented by the host integer type." value="Integer" />

			<Member description="A non-negative integral primitive represented by the host natural-number type." value="NonNegativeInteger" />

			<Member description="An arbitrary-precision decimal primitive represented by the host decimal or rational type." value="Decimal" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:OrderingStrategy
			name="OrderingStrategy"
		>
			<Member description="Compare fields in declared order; the first difference determines the result." value="FieldByFieldComparison" />

			<Member description="Compare variant position first; within the same variant, compare fields for fielded variants, wrapped values for wrapped variants, and treat unit variants as equal." value="VariantThenFieldComparison" />

			<Member description="Delegate the entire comparison to a single field." value="DelegateToField" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:TestValueRole
			name="TestValueRole"
		>
			<Member description="The left operand in an inequality or comparison test." value="Left" />

			<Member description="The right operand in an inequality or comparison test." value="Right" />

			<Member description="The lesser operand in an ordering test." value="Lesser" />

			<Member description="The greater operand in an ordering test." value="Greater" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:Modality
			name="Modality"
		>
			<Member description="The requirement mandates behavior." value="Must" />

			<Member description="The requirement prohibits behavior." value="MustNot" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:SurfaceStatus
			name="SurfaceStatus"
		>
			<Member description="The surface family is current and supported." value="Current" />

			<Member description="The surface family remains accepted for compatibility but is not the preferred current family." value="AcceptedLegacy" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:DispatchKind
			name="DispatchKind"
		>
			<Member description="Dispatch uses a fixed keyword prefix." value="FixedKeywordPrefix" />

			<Member description="Dispatch uses a sigil or other fixed leading marker." value="SigilPrefix" />

			<Member description="Dispatch uses a balanced delimiter family." value="BalancedDelimiter" />

			<Member description="Dispatch uses a bare-token starter class." value="BareTokenPattern" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:TerminationModel
			name="TerminationModel"
		>
			<Member description="The value ends at the matching closing delimiter." value="BalancedDelimiter" />

			<Member description="The value ends at the bare-token boundary defined by the host language." value="BareTokenBoundary" />

			<Member description="The value ends at the closing slash-delimited boundary." value="SlashDelimited" />

			<Member description="The value end is determined by the accepted surface grammar." value="GrammarDefined" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:LongestMatchPolicy
			name="LongestMatchPolicy"
		>
			<Member description="No longest-match rule applies to this dispatch family." value="NotApplicable" />

			<Member description="Competing dispatch starters are resolved by the longest starter." value="PreferLongestStarter" />

			<Member description="Competing recognized forms are resolved by the longest recognized match." value="PreferLongestRecognizedMatch" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:LoweringKind
			name="LoweringKind"
		>
			<Member description="The semantic value lowers to one scalar typed literal." value="ScalarTypedLiteral" />

			<Member description="The semantic value lowers to one structured graph payload." value="StructuredGraph" />

			<Member description="The semantic value lowers through one custom payload operation or calculation." value="CustomPayload" />
		</EnumeratedValueSet>
	</EnumeratedValueSets>

	<ConstraintDefinitions>
		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:variant-fields-or-wraps
			title="A variant carries either named fields or wraps a single type, not both"
		>
			<Targets>
				<TargetConcept conceptSelector="Variant" />
			</Targets>

			<Rule>
				<Not>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="wrapsType" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Field" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</Not>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:type-expression-has-one-form
			title="A type expression uses exactly one expression form"
		>
			<Targets>
				<TargetConcept conceptSelector="TypeExpression" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="NamedTypeReference" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TypeParameterReference" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TypeApplication" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="NamedTypeReference" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TypeParameterReference" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TypeApplication" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="NamedTypeReference" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TypeParameterReference" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TypeApplication" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:named-type-reference-targets-declared-type
			title="A named type reference targets one declared type"
		>
			<Targets>
				<TargetConcept conceptSelector="NamedTypeReference" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="ProductType" />
					</Rule>

					<Rule>
						<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="PrimitiveType" />
					</Rule>

					<Rule>
						<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="CollectionType" />
					</Rule>

					<Rule>
						<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="SumType" />
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:type-application-constructor-targets-declared-type
			title="A type application uses one declared type constructor"
		>
			<Targets>
				<TargetConcept conceptSelector="TypeApplication" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="ProductType" />
					</Rule>

					<Rule>
						<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="CollectionType" />
					</Rule>

					<Rule>
						<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="SumType" />
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:field-has-one-type-source
			title="A field uses either legacy type traits or one structured type expression"
		>
			<Targets>
				<TargetConcept conceptSelector="Field" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="valueType" />
							</Rule>
							<Rule>
								<ChildConstraint conceptSelector="TypeSlot" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="valueType" />
							</Rule>
							<Rule>
								<TraitMissing trait="elementType" />
							</Rule>
							<Rule>
								<ChildConstraint conceptSelector="TypeSlot" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:field-type-slot-role
			title="A structured field type uses the ValueType role"
		>
			<Targets>
				<TargetConcept conceptSelector="Field" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<ChildConstraint conceptSelector="TypeSlot" type=$ForbidsChildConcept />
					</Rule>

					<Rule>
						<OnPathForAll>
							<ChildPath conceptSelector="TypeSlot" />

							<Rule>
								<TraitEquals trait="typeRole" value=$ValueType />
							</Rule>
						</OnPathForAll>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:accessor-arm-returns-one
			title="An accessor arm returns either a field or a constant, not both"
		>
			<Targets>
				<TargetConcept conceptSelector="AccessorArm" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="returnsField" />
							</Rule>

							<Rule>
								<TraitMissing trait="returnsConstant" />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="returnsField" />
							</Rule>

							<Rule>
								<TraitExists trait="returnsConstant" />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:test-argument-has-one-text-source
			title="A test argument uses either a direct value trait or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="TestArgument" />
