<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description=`
		Schema for authoring code specifications in Codex. A code specification is the single
		normative source for any Paperhat product: substrate libraries, extension libraries,
		application workbenches, foundries, language processors, stores, solvers, and graphical,
		terminal, and command-line interfaces. It defines product types, primitive types,
		collection types, sum types, named constants, operations, validation rules,
		library-owned value-surface contracts, formal surface grammars, normative requirements,
		terminology definitions, external references, module descriptions, and conformance cases
		in language-agnostic semantic form. The same document generates human-readable
		documentation through Lexis media foundries and executable implementations in every
		target language through Nexus code foundries. All field types reference Paperhat
		canonical type identifiers, preserving type identity from specification through RDF to
		generated code with zero erasure.
	`
	id=paperhat:domain:codeSpecification
	namespace="codeSpecification"
	title="Code Specification Schema"
	version="1.0.0"
	versionScheme=$SemanticVersion
>
	<SchemaImports>
		<SchemaImport namespace="behavior" reference=urn:cdx:sha256:f813c39f718cd391002edb875ab4a91a78927d7b52700adbdef99c328602168f />

		<SchemaImport namespace="grammar" reference=urn:cdx:sha256:d566fe0a79d0db6d9cab37cef1595820e0552b66a18a71fc21659f1a9077f239 />
	</SchemaImports>

	<ConceptDefinitions>

		[GROUP: Root]

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:CodeSpecification
			name="CodeSpecification"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="title" />

				<RequiresTrait name="version" />

				<RequiresTrait name="license" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="diagnosticType" />

				<AllowsTrait name="contentTransformer" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="ProductType" />

				<AllowsChildConcept conceptSelector="PrimitiveType" />

				<AllowsChildConcept conceptSelector="CollectionType" />

				<AllowsChildConcept conceptSelector="SumType" />

				<AllowsChildConcept conceptSelector="NamedConstant" />

				<AllowsChildConcept conceptSelector="ConstructionOperation" />

				<AllowsChildConcept conceptSelector="AccessorOperation" />

				<AllowsChildConcept conceptSelector="UniformAccessorOperation" />

				<AllowsChildConcept conceptSelector="ValidationRule" />

				<AllowsChildConcept conceptSelector="ValueSurfaceDefinition" />

				<AllowsChildConcept conceptSelector="grammar:Grammar" />

				<AllowsChildConcept conceptSelector="ConstructionTestCase" />

				<AllowsChildConcept conceptSelector="RejectionTestCase" />

				<AllowsChildConcept conceptSelector="InequalityTestCase" />

				<AllowsChildConcept conceptSelector="OrderingTestCase" />

				<AllowsChildConcept conceptSelector="OperationConformanceCase" />

				<AllowsChildConcept conceptSelector="InteropModule" />

				<AllowsChildConcept conceptSelector="ModuleDescription" />

				<AllowsChildConcept conceptSelector="NormativeRequirement" />

				<AllowsChildConcept conceptSelector="TermDefinition" />

				<AllowsChildConcept conceptSelector="ExternalReference" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		[END: Root]

		[GROUP: Type Definitions]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A product type: a type whose instances carry all fields simultaneously. Projected as a struct in Rust, a record in Haskell, a record in OCaml."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:ProductType
			name="ProductType"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specSection" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="capabilities" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="Field" min=1 />

				<AllowsChildConcept conceptSelector="CanonicalOrderingRule" max=1 />

				<AllowsChildConcept conceptSelector="TypeParameter" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A primitive type: an atomic type whose instances are indivisible values rather than records or variants. Projected as a native atomic value according to representationKind."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:PrimitiveType
			name="PrimitiveType"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<RequiresTrait name="representationKind" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specSection" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="capabilities" />
			</TraitRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A collection type constructor identified by a canonical type IRI. Structured type sites apply the constructor through TypeApplication. Legacy field and operation-parameter sites still use elementType. Projected according to collectionKind."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:CollectionType
			name="CollectionType"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<RequiresTrait name="collectionKind" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specSection" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="capabilities" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TypeParameter" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A sum type: a type whose instances carry exactly one variant at a time. Projected as an enum in Rust, a data type in Haskell, a variant type in OCaml."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:SumType
			name="SumType"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specSection" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="capabilities" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="Variant" min=1 />

				<AllowsChildConcept conceptSelector="CanonicalOrderingRule" max=1 />

				<AllowsChildConcept conceptSelector="TypeParameter" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A variant of a sum type. Carries either named fields or wraps a single unnamed value."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:Variant
			key=~variant
			name="Variant"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="position" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="wrapsType" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="Field" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A named field belonging to a product type or a sum type variant."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:Field
			key=~field
			name="Field"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="valueType" />

				<AllowsTrait name="exported" />

				<AllowsTrait name="optional" />

				<AllowsTrait name="position" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="elementType" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TypeSlot" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A type parameter on a generic product type, collection type, or sum type. The foundry generates language-appropriate type parameterization with the declared capability constraints as trait bounds."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TypeParameter
			key=~typeParameter
			name="TypeParameter"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="capabilities" />

				<AllowsTrait name="description" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="A recursive type expression. It resolves to exactly one named type reference, type-parameter reference, or type application."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TypeExpression
			name="TypeExpression"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="NamedTypeReference" max=1 />

				<AllowsChildConcept conceptSelector="TypeParameterReference" max=1 />

				<AllowsChildConcept conceptSelector="TypeApplication" max=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="Binds one site role to one structured type expression."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TypeSlot
			name="TypeSlot"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="typeRole" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="TypeExpression" min=1 max=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="A direct reference to one declared type."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:NamedTypeReference
			name="NamedTypeReference"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="referencedType" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="A reference to one in-scope type parameter."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TypeParameterReference
			name="TypeParameterReference"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="referencedTypeParameter" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="An application of one declared type constructor to one or more ordered type arguments."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TypeApplication
			name="TypeApplication"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="constructorType" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="TypeArgument" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="One ordered type argument supplied to a type application."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TypeArgument
			name="TypeArgument"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="position" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="TypeExpression" min=1 max=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		[END: Type Definitions]

		[GROUP: Named Constants]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A named constant value with a canonical type identifier."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:NamedConstant
			name="NamedConstant"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<RequiresTrait name="valueType" />

				<RequiresTrait name="value" />

				<AllowsTrait name="description" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="position" />
			</TraitRules>
		</ConceptDefinition>

		[END: Named Constants]

		[GROUP: Canonical Ordering]

		<ConceptDefinition
			conceptKind=$Structural
			description="Defines the canonical total ordering for a type. For sum types, same-variant comparison uses field-order rules for fielded variants, wrapped-value comparison for wrapped variants, and equality for unit variants."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:CanonicalOrderingRule
			name="CanonicalOrderingRule"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="strategy" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="delegateField" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="ComparisonStep" />

				<AllowsChildConcept conceptSelector="WithinVariantRule" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="Defines the field comparison order within one field-bearing variant of a sum type."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:WithinVariantRule
			name="WithinVariantRule"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="forVariant" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="ComparisonStep" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A single step in a comparison chain: compare the values of a specific field."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ComparisonStep
			name="ComparisonStep"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="compareField" />

				<RequiresTrait name="position" />
			</TraitRules>
		</ConceptDefinition>

		[END: Canonical Ordering]

		[GROUP: Construction Operations]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A pure operation that produces a value of a specific type. Constructors, parsers, planners, evaluators, transitions, formatters, and other deterministic operations all use this concept. The producesVariant trait identifies the produced variant when the result type is a sum type. WrappedValueBinding binds the carried value when the selected variant uses wrapsType. For PrimitiveType targets, an optional behavior Calculation child defines the produced primitive value."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:ConstructionOperation
			name="ConstructionOperation"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<RequiresTrait name="producesType" />

				<AllowsTrait name="producesVariant" />

				<AllowsTrait name="fallible" />

				<AllowsTrait name="diagnosticVariant" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="optional" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="OperationParameter" />

				<AllowsChildConcept conceptSelector="ConstantBinding" />

				<AllowsChildConcept conceptSelector="WrappedValueBinding" max=1 />

				<AllowsChildConcept conceptSelector="Precondition" />

				<AllowsChildConcept conceptSelector="ProhibitionPrecondition" max=1 />

				<AllowsChildConcept conceptSelector="ValueMapping" max=1 />

				<AllowsChildConcept conceptSelector="behavior:Calculation" max=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A parameter accepted by an operation."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:OperationParameter
			key=~operationParameter
			name="OperationParameter"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="valueType" />

				<RequiresTrait name="position" />

				<AllowsTrait name="mapsToField" />

				<AllowsTrait name="description" />

				<AllowsTrait name="elementType" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Binds a constant value to a target field during construction."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ConstantBinding
			name="ConstantBinding"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="targetField" />

				<RequiresTrait name="boundConstant" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Binds an operation parameter or a named constant to the wrapped value of the produced variant during construction."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:WrappedValueBinding
			name="WrappedValueBinding"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<AllowsTrait name="sourceParameter" />

				<AllowsTrait name="boundConstant" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A validation-rule precondition on an operation parameter."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:Precondition
			name="Precondition"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="validationRule" />

				<RequiresTrait name="appliesToParameter" />

				<RequiresTrait name="failureMessage" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A precondition that prohibits a parameter from equaling a specific constant."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ProhibitionPrecondition
			name="ProhibitionPrecondition"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="parameterToCheck" />

				<RequiresTrait name="prohibitedConstant" />

				<RequiresTrait name="failureMessage" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="Maps a boolean parameter to text values for the lexical form field."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ValueMapping
			name="ValueMapping"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="targetField" />

				<RequiresTrait name="whenTrue" />

				<RequiresTrait name="whenFalse" />
			</TraitRules>
		</ConceptDefinition>

		[END: Construction Operations]

		[GROUP: Accessor Operations]

		<ConceptDefinition
			conceptKind=$Semantic
			description="An accessor operation that returns different values per variant of a sum type."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:AccessorOperation
			name="AccessorOperation"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<RequiresTrait name="returnType" />

				<RequiresTrait name="belongsToType" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specRequirement" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="AccessorArm" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="An accessor operation that returns a field with a stable name from a product type or from every variant of a sum type that exposes that field."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:UniformAccessorOperation
			name="UniformAccessorOperation"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="exported" />

				<RequiresTrait name="returnType" />

				<RequiresTrait name="belongsToType" />

				<RequiresTrait name="accessesFieldNamed" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specRequirement" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="One arm of a variant accessor: specifies what a specific variant returns."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:AccessorArm
			name="AccessorArm"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="forVariant" />

				<AllowsTrait name="returnsField" />

				<AllowsTrait name="returnsConstant" />
			</TraitRules>
		</ConceptDefinition>

		[END: Accessor Operations]

		[GROUP: Validation Rules]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A named validation rule with a behavior expression tree as the single normative definition. The code foundry generates a validation function from the expression tree. The media foundry generates a human-readable description from the expression tree. Conformance tests verify correctness."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:ValidationRule
			name="ValidationRule"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="behavior:Validation" max=1 />
			</ChildRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="appliesToType" />

				<AllowsTrait name="description" />

				<AllowsTrait name="specRequirement" />

				<AllowsTrait name="validationPattern" />
			</TraitRules>
		</ConceptDefinition>

		[END: Validation Rules]

		[GROUP: Value Surfaces]

		<ConceptDefinition
			conceptKind=$Semantic
			description="One library-owned authorable value family. It binds one semantic target type, one canonical rendering operation, and one or more accepted surface forms, each with its own construction operation and parse contract."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:ValueSurfaceDefinition
			name="ValueSurfaceDefinition"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="targetType" />

				<RequiresTrait name="canonicalRenderingOperation" />

				<RequiresTrait name="surfaceStatus" />

				<AllowsTrait name="description" />

				<AllowsTrait name="longDescription" />

				<AllowsTrait name="specSection" />

				<AllowsTrait name="specRequirement" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="DispatchContract" min=1 max=1 />

				<RequiresChildConcept conceptSelector="AcceptedSurfaceForm" min=1 />

				<AllowsChildConcept conceptSelector="SurfacePayloadField" />

				<AllowsChildConcept conceptSelector="SurfaceLoweringContract" />

				<RequiresChildConcept conceptSelector="SurfaceAcceptanceCase" min=1 />

				<AllowsChildConcept conceptSelector="SurfaceRejectionCase" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="The machine-readable entry contract used by a host-language parser to route input to one imported value surface definition."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:DispatchContract
			name="DispatchContract"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="dispatchKind" />

				<RequiresTrait name="precedence" />

				<RequiresTrait name="terminationModel" />

				<RequiresTrait name="longestMatchPolicy" />

				<AllowsTrait name="starterLiteral" />

				<AllowsTrait name="starterDelimiter" />

				<AllowsTrait name="reservedKeyword" />

				<AllowsTrait name="bareTokenClass" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="One accepted spelling family for a value surface definition. Each accepted form binds one construction operation, one exact grammar, zero or more payload captures, and one parse binding."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:AcceptedSurfaceForm
			name="AcceptedSurfaceForm"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="canonical" />

				<RequiresTrait name="constructionOperation" />

				<AllowsTrait name="description" />

				<AllowsTrait name="specSection" />

				<AllowsTrait name="specRequirement" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="grammar:Grammar" min=1 max=1 />

				<AllowsChildConcept conceptSelector="SurfacePayloadCapture" />

				<RequiresChildConcept conceptSelector="SurfaceParseBinding" min=1 max=1 />

				<AllowsChildConcept conceptSelector="behavior:Validation" max=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="One typed payload component captured from an accepted surface form."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:SurfacePayloadField
			name="SurfacePayloadField"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="position" />

				<RequiresTrait name="valueType" />

				<AllowsTrait name="description" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="One mapping from a grammar capture symbol to a declared typed payload field. An optional capture construction operation converts the raw capture text before the payload field is exposed to argument binding."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:SurfacePayloadCapture
			name="SurfacePayloadCapture"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="payloadField" />

				<RequiresTrait name="captureSymbol" />

				<AllowsTrait name="captureConstructionOperation" />

				<AllowsTrait name="description" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="The deterministic mapping from typed surface payload fields to constructor-operation arguments."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:SurfaceParseBinding
			name="SurfaceParseBinding"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="SurfaceArgumentBinding" min=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="One binding that supplies exactly one constructor-operation parameter from one payload field, one constant, or one computed expression over payload fields."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:SurfaceArgumentBinding
			name="SurfaceArgumentBinding"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="parameter" />

				<AllowsTrait name="payloadField" />

				<AllowsTrait name="boundConstant" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="behavior:Calculation" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="The exact lowering contract from the semantic value to a language-neutral payload shape used by IR or RDF lowering."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:SurfaceLoweringContract
			name="SurfaceLoweringContract"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="loweringKind" />

				<AllowsTrait name="payloadOperation" />

				<AllowsTrait name="datatypeIri" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="behavior:Calculation" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="An exact conformance case for one accepted input spelling of a value surface definition."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:SurfaceAcceptanceCase
			name="SurfaceAcceptanceCase"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="testName" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="InputSpelling" min=1 max=1 />

				<RequiresChildConcept conceptSelector="ExpectedCanonicalSpelling" min=1 max=1 />

				<AllowsChildConcept conceptSelector="ExpectedSurfacePayloadValue" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="An exact conformance case for one rejected input spelling of a value surface definition."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:SurfaceRejectionCase
			name="SurfaceRejectionCase"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="testName" />

				<RequiresTrait name="expectedDiagnostic" />

				<AllowsTrait name="expectedFailureContaining" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="InputSpelling" min=1 max=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="One exact authored input spelling for a surface acceptance or rejection case."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:InputSpelling
			name="InputSpelling"
		>
			<ContentRules>
				<AllowsContentOrChildren whitespaceMode=$Preformatted />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="The exact canonical spelling expected from canonical rendering of an accepted surface input."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ExpectedCanonicalSpelling
			name="ExpectedCanonicalSpelling"
		>
			<ContentRules>
				<AllowsContentOrChildren whitespaceMode=$Preformatted />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="One exact expected payload value captured for a named surface payload field."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ExpectedSurfacePayloadValue
			name="ExpectedSurfacePayloadValue"
		>
			<ContentRules>
				<AllowsContentOrChildren whitespaceMode=$Preformatted />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="payloadField" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		[END: Value Surfaces]

		[GROUP: Test Cases]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A test that constructs a value and asserts accessor results."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ConstructionTestCase
			name="ConstructionTestCase"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="testName" />

				<RequiresTrait name="operation" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TestArgument" />

				<AllowsChildConcept conceptSelector="ExpectedAccessorResult" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A test that asserts an operation rejects invalid input."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:RejectionTestCase
			name="RejectionTestCase"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="testName" />

				<RequiresTrait name="operation" />

				<RequiresTrait name="expectedFailureContaining" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TestArgument" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A test that asserts two constructed values are not equal."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:InequalityTestCase
			name="InequalityTestCase"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="testName" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="TestValue" min=2 max=2 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A test that asserts one constructed value is less than another."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:OrderingTestCase
			name="OrderingTestCase"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="testName" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="TestValue" min=2 max=2 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A value constructed for use in a test case."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TestValue
			name="TestValue"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="role" />

				<RequiresTrait name="operation" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TestArgument" />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="An argument passed to an operation in a test case."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TestArgument
			name="TestArgument"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<AllowsTrait name="value" />

				<RequiresTrait name="position" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Structural
			description="A reviewable Text encoding authored as an ordered list of Character values."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:TextByScalars
			name="TextByScalars"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="scalars" />
			</TraitRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="An expected result from calling an accessor on a constructed value."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ExpectedAccessorResult
			name="ExpectedAccessorResult"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="accessor" />

				<AllowsTrait name="expectedValue" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="A test that invokes any operation with exact typed arguments and asserts one exact success value or one exact diagnostic value."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:OperationConformanceCase
			name="OperationConformanceCase"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="testName" />

				<RequiresTrait name="operation" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="OperationArgument" />

				<AllowsChildConcept conceptSelector="ExpectedOperationValue" max=1 />

				<AllowsChildConcept conceptSelector="ExpectedDiagnosticValue" max=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="One typed argument supplied to an operation conformance case. The content is the canonical Codex literal or canonical Codex fragment for the argument value. Product values use the product tag; primitive fields may be attributes; complex fields use field-named child wrappers. Sum values use the selected variant tag. Wrapped variants contain one child fragment for the wrapped value. Ordered list fields use one field-named wrapper containing the ordered child fragments."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:OperationArgument
			name="OperationArgument"
		>
			<ContentRules>
				<AllowsContentOrChildren whitespaceMode=$Preformatted />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="position" />

				<RequiresTrait name="valueType" />

				<AllowsTrait name="parameterName" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="The exact success value expected from an operation conformance case. The content is the canonical Codex literal or canonical Codex fragment for the returned value. Product, sum, wrapped-variant, and ordered-list encoding follow the same canonical fragment rules defined for OperationArgument."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ExpectedOperationValue
			name="ExpectedOperationValue"
		>
			<ContentRules>
				<AllowsContentOrChildren whitespaceMode=$Preformatted />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="valueType" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			description="The exact diagnostic value expected from an operation conformance case. The content is the canonical Codex fragment for the returned diagnostic value. Product, sum, wrapped-variant, and ordered-list encoding follow the same canonical fragment rules defined for OperationArgument."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ExpectedDiagnosticValue
			name="ExpectedDiagnosticValue"
		>
			<ContentRules>
				<AllowsContentOrChildren whitespaceMode=$Preformatted />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="valueType" />

				<RequiresTrait name="diagnosticVariant" />

				<AllowsTrait name="description" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="TextByScalars" max=1 />
			</ChildRules>
		</ConceptDefinition>

		[END: Test Cases]

		[GROUP: Interop]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A language-specific interop module. Foundries for the target language generate the interop code; other foundries ignore it."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:InteropModule
			name="InteropModule"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="conditionalOn" />

				<RequiresTrait name="targetLibrary" />

				<AllowsTrait name="description" />
			</TraitRules>
		</ConceptDefinition>

		[END: Interop]

		[GROUP: Module Descriptions]

		<ConceptDefinition
			conceptKind=$Structural
			description="Describes a source module in the generated code. The foundry uses module descriptions to generate module-level documentation comments."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ModuleDescription
			name="ModuleDescription"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="description" />
			</TraitRules>
		</ConceptDefinition>

		[END: Module Descriptions]

		[GROUP: Normative Requirements]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A normative requirement that governs the specification as a whole or defines a cross-cutting policy, behavioral mandate, or contract clause not tied to a specific type or operation. The media foundry generates requirement prose. The code foundry generates doc comments, compile-time assertions, or policy-enforcement code as appropriate for the target language."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:NormativeRequirement
			name="NormativeRequirement"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<RequiresTrait name="modality" />

				<RequiresTrait name="description" />

				<AllowsTrait name="rationale" />

				<AllowsTrait name="specSection" />
			</TraitRules>
		</ConceptDefinition>

		[END: Normative Requirements]

		[GROUP: Term Definitions]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A formal terminology definition that establishes the precise meaning of a term used throughout the specification. The media foundry generates a glossary entry. The code foundry generates a doc comment on the module or crate that references the term."
			entityEligibility=$MustBeEntity
			id=paperhat:domain:codeSpecification:TermDefinition
			name="TermDefinition"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="term" />

				<RequiresTrait name="description" />

				<AllowsTrait name="longDescription" />
			</TraitRules>
		</ConceptDefinition>

		[END: Term Definitions]

		[GROUP: External References]

		<ConceptDefinition
			conceptKind=$Semantic
			description="A reference to an external standard, specification, or resource that this code specification depends on or cites. The media foundry generates a references section. The code foundry generates doc-comment links or crate-level documentation references."
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:codeSpecification:ExternalReference
			name="ExternalReference"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="label" />

				<RequiresTrait name="uri" />

				<AllowsTrait name="description" />
			</TraitRules>
		</ConceptDefinition>

		[END: External References]

	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$LookupToken
			id=paperhat:domain:codeSpecification:trait:key
			name="key"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:codeSpecification:trait:title
			name="title"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$SemanticVersion
			id=paperhat:domain:codeSpecification:trait:version
			name="version"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:codeSpecification:trait:license
			name="license"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:codeSpecification:trait:description
			name="description"
			priority=$Secondary
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:codeSpecification:trait:longDescription
			name="longDescription"
			priority=$Secondary
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:codeSpecification:trait:name
			name="name"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:codeSpecification:trait:testName
			name="testName"
			priority=$Primary
		/>


		<TraitDefinition
			defaultValueType=$Boolean
			id=paperhat:domain:codeSpecification:trait:exported
			name="exported"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$NonNegativeInteger
			id=paperhat:domain:codeSpecification:trait:position
			name="position"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:codeSpecification:trait:parameterName
			name="parameterName"
			priority=$Secondary
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:codeSpecification:trait:valueType
			name="valueType"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:codeSpecification:trait:elementType
			name="elementType"
			priority=$Secondary
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:codeSpecification:trait:wrapsType
			name="wrapsType"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:codeSpecification:trait:referencedType
			isReferenceTrait=true
			name="referencedType"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$LookupToken
			id=paperhat:domain:codeSpecification:trait:referencedTypeParameter
			name="referencedTypeParameter"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:codeSpecification:trait:constructorType
			isReferenceTrait=true
			name="constructorType"
			priority=$Primary
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:codeSpecification:trait:typeRole
			name="typeRole"
			priority=$Primary
