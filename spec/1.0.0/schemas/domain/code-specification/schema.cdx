	<EnumeratedValueSets>
		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:Capability
			name="Capability"
		>
			<Member description="Instances are comparable for structural equality." value="Equality" />

			<Member description="Instances produce a deterministic hash value." value="Hashing" />

			<Member description="Instances are duplicatable." value="Cloning" />

			<Member description="Instances have a canonical total ordering." value="CanonicalOrdering" />

			<Member description="Instances have a debug text representation." value="Debugging" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:PrimitiveRepresentationKind
			name="PrimitiveRepresentationKind"
		>
			<Member description="A two-valued logical primitive projected to the host boolean representation." value="Boolean" />

			<Member description="A primitive represented by the host text type." value="Text" />

			<Member description="A signed integral primitive represented by the host integer type." value="Integer" />

			<Member description="A non-negative integral primitive represented by the host natural-number type." value="NonNegativeInteger" />

			<Member description="An arbitrary-precision decimal primitive represented by the host decimal or rational type." value="Decimal" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:OrderingStrategy
			name="OrderingStrategy"
		>
			<Member description="Compare fields in declared order; the first difference determines the result." value="FieldByFieldComparison" />

			<Member description="Compare variant position first; within the same variant, compare fields in declared order." value="VariantThenFieldComparison" />

			<Member description="Delegate the entire comparison to a single field." value="DelegateToField" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:TestValueRole
			name="TestValueRole"
		>
			<Member description="The left operand in an inequality or comparison test." value="Left" />

			<Member description="The right operand in an inequality or comparison test." value="Right" />

			<Member description="The lesser operand in an ordering test." value="Lesser" />

			<Member description="The greater operand in an ordering test." value="Greater" />
		</EnumeratedValueSet>

		<EnumeratedValueSet
			id=paperhat:domain:codeSpecification:set:Modality
			name="Modality"
		>
			<Member description="The requirement mandates behavior." value="Must" />

			<Member description="The requirement prohibits behavior." value="MustNot" />
		</EnumeratedValueSet>
	</EnumeratedValueSets>

	<ConstraintDefinitions>
		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:variant-fields-or-wraps
			title="A variant carries either named fields or wraps a single type, not both"
		>
			<Targets>
				<TargetConcept conceptSelector="Variant" />
			</Targets>

			<Rule>
				<Not>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="wrapsType" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="Field" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</Not>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:accessor-arm-returns-one
			title="An accessor arm returns either a field or a constant, not both"
		>
			<Targets>
				<TargetConcept conceptSelector="AccessorArm" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="returnsField" />
							</Rule>

							<Rule>
								<TraitMissing trait="returnsConstant" />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="returnsField" />
							</Rule>

							<Rule>
								<TraitExists trait="returnsConstant" />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:test-argument-has-one-text-source
			title="A test argument uses either a direct value trait or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="TestArgument" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="value" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="value" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:expected-accessor-result-has-one-text-source
			title="An expected accessor result uses either expectedValue or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="ExpectedAccessorResult" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="expectedValue" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="expectedValue" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:operation-argument-has-one-text-source
			title="An operation argument uses either content or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="OperationArgument" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ContentRequired />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ForbidsContent />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:expected-operation-value-has-one-text-source
			title="An expected operation value uses either content or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="ExpectedOperationValue" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ContentRequired />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ForbidsContent />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:expected-diagnostic-value-has-one-text-source
			title="An expected diagnostic value uses either content or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="ExpectedDiagnosticValue" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ContentRequired />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ForbidsContent />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:operation-conformance-has-one-expected
			title="An operation conformance case expects either one success value or one diagnostic value"
		>
			<Targets>
				<TargetConcept conceptSelector="OperationConformanceCase" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="ExpectedOperationValue" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ExpectedDiagnosticValue" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="ExpectedOperationValue" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ExpectedDiagnosticValue" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:primitive-construction-operation-shape
			title="A primitive-producing construction operation uses calculation-based construction"
		>
			<Targets>
				<TargetConcept conceptSelector="ConstructionOperation" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="PrimitiveType" />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<TraitMissing trait="producesVariant" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ConstantBinding" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ValueMapping" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>
	</ConstraintDefinitions>
</Schema>
