			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-payload-capture-construction-operation-targets-construction-operation
			title="A surface payload capture conversion operation targets one declared construction operation"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfacePayloadCapture" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<TraitMissing trait="captureConstructionOperation" />
					</Rule>

					<Rule>
						<ReferenceConstraint
							conceptSelector="ConstructionOperation"
							traitName="captureConstructionOperation"
							type=$ReferenceTargetsConcept
						/>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-argument-binding-parameter-targets-operation-parameter
			title="A surface argument binding targets one declared operation parameter"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceArgumentBinding" />
			</Targets>

			<Rule>
				<ReferenceConstraint
					conceptSelector="OperationParameter"
					traitName="parameter"
					type=$ReferenceTargetsConcept
				/>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-argument-binding-payload-field-targets-declared-payload-field
			title="A surface argument binding payload field targets one declared surface payload field"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceArgumentBinding" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<TraitMissing trait="payloadField" />
					</Rule>

					<Rule>
						<ReferenceConstraint
							conceptSelector="SurfacePayloadField"
							traitName="payloadField"
							type=$ReferenceTargetsConcept
						/>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-lowering-contract-payload-operation-targets-operation
			title="A surface lowering contract payload operation targets one declared operation"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceLoweringContract" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<TraitMissing trait="payloadOperation" />
					</Rule>

					<Rule>
						<ReferenceConstraint
							conceptSelector="ConstructionOperation"
							traitName="payloadOperation"
							type=$ReferenceTargetsConcept
						/>
					</Rule>

					<Rule>
						<ReferenceConstraint
							conceptSelector="AccessorOperation"
							traitName="payloadOperation"
							type=$ReferenceTargetsConcept
						/>
					</Rule>

					<Rule>
						<ReferenceConstraint
							conceptSelector="UniformAccessorOperation"
							traitName="payloadOperation"
							type=$ReferenceTargetsConcept
						/>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:expected-surface-payload-value-payload-field-targets-declared-payload-field
			title="An expected surface payload value targets one declared surface payload field"
		>
			<Targets>
				<TargetConcept conceptSelector="ExpectedSurfacePayloadValue" />
			</Targets>

			<Rule>
				<ReferenceConstraint
					conceptSelector="SurfacePayloadField"
					traitName="payloadField"
					type=$ReferenceTargetsConcept
				/>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:value-surface-has-exactly-one-canonical-form
			title="A value surface definition has exactly one canonical accepted form"
		>
			<Targets>
				<TargetConcept conceptSelector="ValueSurfaceDefinition" />
			</Targets>

			<Rule>
				<OnPathCount minCount=1 maxCount=1>
					<ChildPath conceptSelector="AcceptedSurfaceForm" />

					<Rule>
						<TraitEquals trait="canonical" value=true />
					</Rule>
				</OnPathCount>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:value-surface-payload-field-positions-are-unique
			title="A value surface definition uses each payload-field position at most once"
		>
			<Targets>
				<TargetConcept conceptSelector="ValueSurfaceDefinition" />
			</Targets>

			<Rule>
				<CollectionAllowsDuplicates allowed=false keyTrait="position">
					<ChildPath conceptSelector="SurfacePayloadField" />
				</CollectionAllowsDuplicates>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:accepted-surface-form-payload-fields-are-unique
			title="An accepted surface form binds each payload field at most once"
		>
			<Targets>
				<TargetConcept conceptSelector="AcceptedSurfaceForm" />
			</Targets>

			<Rule>
				<CollectionAllowsDuplicates allowed=false keyTrait="payloadField">
					<ChildPath conceptSelector="SurfacePayloadCapture" />
				</CollectionAllowsDuplicates>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-parse-binding-parameters-are-unique
			title="A surface parse binding binds each constructor parameter at most once"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceParseBinding" />
			</Targets>

			<Rule>
				<CollectionAllowsDuplicates allowed=false keyTrait="parameter">
					<ChildPath conceptSelector="SurfaceArgumentBinding" />
				</CollectionAllowsDuplicates>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-acceptance-payload-fields-are-unique
			title="A surface acceptance case expects each payload field at most once"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceAcceptanceCase" />
			</Targets>

			<Rule>
				<CollectionAllowsDuplicates allowed=false keyTrait="payloadField">
					<ChildPath conceptSelector="ExpectedSurfacePayloadValue" />
				</CollectionAllowsDuplicates>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-argument-binding-has-exactly-one-source
			title="A surface argument binding uses exactly one source"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceArgumentBinding" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="payloadField" />
							</Rule>

							<Rule>
								<TraitMissing trait="boundConstant" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="payloadField" />
							</Rule>

							<Rule>
								<TraitExists trait="boundConstant" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="payloadField" />
							</Rule>

							<Rule>
								<TraitMissing trait="boundConstant" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:input-spelling-has-one-text-source
			title="An input spelling uses either content or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="InputSpelling" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ContentRequired />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ForbidsContent />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:expected-canonical-spelling-has-one-text-source
			title="An expected canonical spelling uses either content or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="ExpectedCanonicalSpelling" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ContentRequired />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ForbidsContent />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:expected-surface-payload-has-one-text-source
			title="An expected surface payload value uses either content or one TextByScalars child"
		>
			<Targets>
				<TargetConcept conceptSelector="ExpectedSurfacePayloadValue" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ContentRequired />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContentConstraint type=$ForbidsContent />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="TextByScalars" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-lowering-scalar-typed-literal-shape
			title="A scalar typed-literal lowering requires datatypeIri and forbids payload decomposition hooks"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceLoweringContract" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<TraitEquals trait="loweringKind" value=$ScalarTypedLiteral />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitEquals trait="loweringKind" value=$ScalarTypedLiteral />
							</Rule>

							<Rule>
								<TraitExists trait="datatypeIri" />
							</Rule>

							<Rule>
								<TraitMissing trait="payloadOperation" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-lowering-structured-graph-shape
			title="A structured-graph lowering forbids datatypeIri and payload decomposition hooks"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceLoweringContract" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<TraitEquals trait="loweringKind" value=$StructuredGraph />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitEquals trait="loweringKind" value=$StructuredGraph />
							</Rule>

							<Rule>
								<TraitMissing trait="datatypeIri" />
							</Rule>

							<Rule>
								<TraitMissing trait="payloadOperation" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-lowering-custom-payload-shape
			title="A custom-payload lowering requires one payload hook and forbids datatypeIri"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfaceLoweringContract" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<TraitEquals trait="loweringKind" value=$CustomPayload />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitEquals trait="loweringKind" value=$CustomPayload />
							</Rule>

							<Rule>
								<TraitMissing trait="datatypeIri" />
							</Rule>

							<Rule>
								<AnyOf>
									<Rule>
										<TraitExists trait="payloadOperation" />
									</Rule>

									<Rule>
										<ChildConstraint conceptSelector="behavior:Calculation" type=$RequiresChildConcept />
									</Rule>
								</AnyOf>
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:wrapped-value-binding-has-one-source
			title="A wrapped-value binding uses either one source parameter or one bound constant"
		>
			<Targets>
				<TargetConcept conceptSelector="WrappedValueBinding" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="sourceParameter" />
							</Rule>

							<Rule>
								<TraitMissing trait="boundConstant" />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitMissing trait="sourceParameter" />
							</Rule>

							<Rule>
								<TraitExists trait="boundConstant" />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:operation-conformance-has-one-expected
			title="An operation conformance case expects either one success value or one diagnostic value"
		>
			<Targets>
				<TargetConcept conceptSelector="OperationConformanceCase" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="ExpectedOperationValue" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ExpectedDiagnosticValue" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="ExpectedOperationValue" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ExpectedDiagnosticValue" type=$RequiresChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:primitive-construction-operation-shape
			title="A primitive-producing construction operation uses calculation-based construction"
		>
			<Targets>
				<TargetConcept conceptSelector="ConstructionOperation" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<ReferenceConstraint type=$ReferenceTargetsConcept conceptSelector="PrimitiveType" />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$RequiresChildConcept />
							</Rule>

							<Rule>
								<TraitMissing trait="producesVariant" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ConstantBinding" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="WrappedValueBinding" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ValueMapping" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:wrapped-value-construction-shape
			title="A wrapped-value construction operation uses variant-bound direct binding"
		>
			<Targets>
				<TargetConcept conceptSelector="ConstructionOperation" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<ChildConstraint conceptSelector="WrappedValueBinding" type=$RequiresChildConcept />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<TraitExists trait="producesVariant" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ConstantBinding" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ValueMapping" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="behavior:Calculation" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<OnPathForAll>
									<ChildPath conceptSelector="OperationParameter" />

									<Rule>
										<TraitMissing trait="mapsToField" />
									</Rule>
								</OnPathForAll>
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:field-by-field-ordering-shape
			title="FieldByFieldComparison applies only to product-type field comparisons"
		>
			<Targets>
				<TargetConcept conceptSelector="CanonicalOrderingRule" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<TraitEquals trait="strategy" value=$FieldByFieldComparison />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContextConstraint contextSelector="ProductType" type=$OnlyValidUnderContext />
							</Rule>

							<Rule>
								<TraitMissing trait="delegateField" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="WithinVariantRule" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:variant-then-field-ordering-shape
			title="VariantThenFieldComparison applies only to sum-type ordering"
		>
			<Targets>
				<TargetConcept conceptSelector="CanonicalOrderingRule" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<TraitEquals trait="strategy" value=$VariantThenFieldComparison />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContextConstraint contextSelector="SumType" type=$OnlyValidUnderContext />
							</Rule>

							<Rule>
								<TraitMissing trait="delegateField" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ComparisonStep" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:delegate-ordering-shape
			title="DelegateToField applies only to product-type single-field delegation"
		>
			<Targets>
				<TargetConcept conceptSelector="CanonicalOrderingRule" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<Not>
							<Rule>
								<TraitEquals trait="strategy" value=$DelegateToField />
							</Rule>
						</Not>
					</Rule>

					<Rule>
						<AllOf>
							<Rule>
								<ContextConstraint contextSelector="ProductType" type=$OnlyValidUnderContext />
							</Rule>

							<Rule>
								<TraitExists trait="delegateField" />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="ComparisonStep" type=$ForbidsChildConcept />
							</Rule>

							<Rule>
								<ChildConstraint conceptSelector="WithinVariantRule" type=$ForbidsChildConcept />
							</Rule>
						</AllOf>
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>
	</ConstraintDefinitions>
</Schema>
