					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:value-surface-target-type-targets-declared-type
			title="A value surface definition targets one declared type"
		>
			<Targets>
				<TargetConcept conceptSelector="ValueSurfaceDefinition" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<ReferenceConstraint traitName="targetType" type=$ReferenceTargetsConcept conceptSelector="ProductType" />
					</Rule>

					<Rule>
						<ReferenceConstraint traitName="targetType" type=$ReferenceTargetsConcept conceptSelector="PrimitiveType" />
					</Rule>

					<Rule>
						<ReferenceConstraint traitName="targetType" type=$ReferenceTargetsConcept conceptSelector="CollectionType" />
					</Rule>

					<Rule>
						<ReferenceConstraint traitName="targetType" type=$ReferenceTargetsConcept conceptSelector="SumType" />
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>

		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:value-surface-rendering-operation-targets-construction-operation
