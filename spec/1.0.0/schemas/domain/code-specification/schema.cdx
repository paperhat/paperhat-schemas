		<ConstraintDefinition
			id=paperhat:domain:codeSpecification:surface-payload-capture-payload-field-targets-declared-payload-field
			title="A surface payload capture targets one declared surface payload field"
		>
			<Targets>
				<TargetConcept conceptSelector="SurfacePayloadCapture" />
			</Targets>

			<Rule>
				<ReferenceConstraint
					conceptSelector="SurfacePayloadField"
