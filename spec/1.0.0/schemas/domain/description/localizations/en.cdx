<LocalizationBundle
	schema=paperhat:domain:description
	schemaVersion="1.0.0"
	language=language-tag("en")
>
	<ConceptLocalization identifier="Description" label="Description" labelOther="Descriptions" />

	<TraitLocalization identifier="language" label="Language" labelOther="Languages">
		The natural language of the description content.
	</TraitLocalization>
</LocalizationBundle>
