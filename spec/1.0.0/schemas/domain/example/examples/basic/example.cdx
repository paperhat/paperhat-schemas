<Example key=~apiUsageExample label="API Usage Example">
	<text:Title>
		Create a Figure Entry
	</text:Title>

	<text:Paragraph>
		Call the publish endpoint with a validated figure payload.
	</text:Paragraph>

	<code:CodeBlock language=$Bash>
		curl -X POST https://api.example.com/v1/figures \
		  -H "Content-Type: application/json" \
		  -d '{"caption":"System architecture","url":"https://example.com/arch.svg"}'
	</code:CodeBlock>
</Example>
