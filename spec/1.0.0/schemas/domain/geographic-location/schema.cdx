<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="A precise geographic position expressed as latitude, longitude, and optional elevation."
	id=paperhat:domain:geographic-location
	namespace="geo"
	title="Geographic Location Schema"
	version="1.0.0"
	versionScheme=$SemanticVersion
>
	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:geographic-location:GeographicLocation
			name="GeographicLocation"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="latitude" />

				<RequiresTrait name="longitude" />

				<AllowsTrait name="elevation" />
			</TraitRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$Number
			id=paperhat:domain:geographic-location:trait:latitude
			name="latitude"
		/>

		<TraitDefinition
			defaultValueType=$Number
			id=paperhat:domain:geographic-location:trait:longitude
			name="longitude"
		/>

		<TraitDefinition
			defaultValueType=$Number
			id=paperhat:domain:geographic-location:trait:elevation
			name="elevation"
		/>
	</TraitDefinitions>
</Schema>
