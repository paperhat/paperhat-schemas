<OrderedList>
	<ListItem bodyMode=$content>
		Preheat the oven to 180 °C.
	</ListItem>

	<ListItem bodyMode=$content>
		Mix the dry ingredients in a large bowl.
	</ListItem>

	<ListItem bodyMode=$content>
		Add the wet ingredients and stir until just combined.
	</ListItem>

	<ListItem bodyMode=$content>
		Pour into a greased baking tin and bake for 25 minutes.
	</ListItem>
</OrderedList>
