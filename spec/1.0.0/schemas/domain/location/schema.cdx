<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="A named geographic or fictional location with optional administrative subdivisions."
	id=paperhat:domain:location
	namespace="loc"
	title="Location Schema"
	version="1.0.0"
	versionScheme=$SemanticVersion
>
	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:location:Location
			name="Location"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<AllowsTrait name="locationKind" />

				<AllowsTrait name="name" />

				<AllowsTrait name="locality" />

				<AllowsTrait name="region" />

				<AllowsTrait name="country" />
			</TraitRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:location:trait:locationKind
			name="locationKind"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:location:trait:name
			name="name"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:location:trait:locality
			name="locality"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:location:trait:region
			name="region"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:location:trait:country
			name="country"
		/>
	</TraitDefinitions>

	<ConstraintDefinitions>
		<ConstraintDefinition
			id=paperhat:domain:location:requires-location-part
			title="Location must have at least one location part"
		>
			<Targets>
				<TargetConcept conceptSelector="Location" />
			</Targets>

			<Rule>
				<AnyOf>
					<Rule>
						<TraitExists trait="name" />
					</Rule>

					<Rule>
						<TraitExists trait="locality" />
					</Rule>

					<Rule>
						<TraitExists trait="region" />
					</Rule>

					<Rule>
						<TraitExists trait="country" />
					</Rule>
				</AnyOf>
			</Rule>
		</ConstraintDefinition>
	</ConstraintDefinitions>
</Schema>
