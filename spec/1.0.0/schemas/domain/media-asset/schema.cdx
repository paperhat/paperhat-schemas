<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="A discrete media file or object with identity, such as an image, video, audio recording, or document file, carrying technical metadata about the asset itself."
	id=paperhat:domain:media-asset
	namespace="asset"
	title="Media Asset Schema"
	version="1.0.0"
	versionScheme=$Semver
>
	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:media-asset:MediaAsset
			name="MediaAsset"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="assetKind" />

				<AllowsTrait name="url" />

				<AllowsTrait name="encodingFormat" />

				<AllowsTrait name="altText" />
			</TraitRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:media-asset:trait:name
			name="name"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:media-asset:trait:assetKind
			name="assetKind"
		/>

		<TraitDefinition
			defaultValueType=$Url
			id=paperhat:domain:media-asset:trait:url
			name="url"
		/>

		<TraitDefinition
			defaultValueType=$MediaType
			id=paperhat:domain:media-asset:trait:encodingFormat
			name="encodingFormat"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:media-asset:trait:altText
			name="altText"
		/>
	</TraitDefinitions>
</Schema>
