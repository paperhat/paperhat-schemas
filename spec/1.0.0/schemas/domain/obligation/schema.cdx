<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description=`
		A binding commitment by a party to perform or refrain from an action — a contractual,
		regulatory, or policy obligation with a responsible party and compliance state.
	`
	id=paperhat:domain:obligation
	namespace="obligation"
	title="Obligation Schema"
	version="1.0.0"
	versionScheme=$SemanticVersion
>
	<SchemaImports>
		<SchemaImport
			namespace="desc"
			reference=urn:cdx:sha256:a83c22466ae563559a998dfb4977c4b1c56d53cb1bc2963859bc60059949afce
		/>
	</SchemaImports>

	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:obligation:Obligation
			name="Obligation"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="dueDate" />

				<AllowsTrait name="obligatedParty" />

				<AllowsTrait name="obligationKind" />

				<AllowsTrait name="obligationStatus" />
			</TraitRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="desc:Description" />
			</ChildRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$Date
			id=paperhat:domain:obligation:trait:dueDate
			name="dueDate"
		/>

		<TraitDefinition defaultValueType=$Text id=paperhat:domain:obligation:trait:name name="name" />

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:obligation:trait:obligatedParty
			isReferenceTrait=true
			name="obligatedParty"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:obligation:trait:obligationKind
			name="obligationKind"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:obligation:trait:obligationStatus
			name="obligationStatus"
		/>
	</TraitDefinitions>
</Schema>
