<Organization
	name="East India Company"
	organizationKind=$corporation
	foundingDate={1600-12-31}
	dissolutionDate={1874-06-01}
>
	<Description>
		A chartered trading company that dominated trade across the Indian Ocean
		for over two centuries.
	</Description>

	<Location locationKind=$headquarters locality="London" country="England" />

	<Tags>
		<Tag>
			archival
		</Tag>

		<Tag>
			trade
		</Tag>

		<Tag>
			colonial
		</Tag>
	</Tags>
</Organization>
