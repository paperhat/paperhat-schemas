>
	<ConceptLocalization identifier="PrismProject" label="Prism Project" labelOther="Prism Projects" />

	<ConceptLocalization identifier="GovernancePack" label="Governance Pack" labelOther="Governance Packs" />

	<ConceptLocalization identifier="SourceReference" label="Source Reference" labelOther="Source References" />

	<ConceptLocalization identifier="ReviewDisposition" label="Review Disposition" labelOther="Review Dispositions" />

	<ConceptLocalization identifier="PublicationScope" label="Publication Scope" labelOther="Publication Scopes" />

	<TraitLocalization identifier="title" label="Title" labelOther="Titles">
