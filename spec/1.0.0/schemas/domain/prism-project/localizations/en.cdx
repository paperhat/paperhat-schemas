	</TraitLocalization>

	<TraitLocalization identifier="prismProjectStatus" label="Prism Project Status" labelOther="Prism Project Statuses">
		Lifecycle or governance status for a Prism project.
	</TraitLocalization>

	<TraitLocalization identifier="name" label="Name" labelOther="Names">
		Human-readable governance-pack name.
	</TraitLocalization>

	<TraitLocalization identifier="governancePackStatus" label="Governance Pack Status" labelOther="Governance Pack Statuses">
		Lifecycle or governance status for a governance pack.
	</TraitLocalization>

	<TraitLocalization identifier="key" label="Key" labelOther="Keys">
		Stable document-scoped lookup key.
	</TraitLocalization>

	<TraitLocalization identifier="label" label="Label" labelOther="Labels">
		Human-readable display label.
	</TraitLocalization>

	<TraitLocalization identifier="sourceKind" label="Source Kind" labelOther="Source Kinds">
		Open classification for a source reference.
	</TraitLocalization>

	<TraitLocalization identifier="sourceLocator" label="Source Locator" labelOther="Source Locators">
		External IRI for a source reference.
	</TraitLocalization>

	<TraitLocalization identifier="sourceStatus" label="Source Status" labelOther="Source Statuses">
		Lifecycle or governance status for a source reference.
	</TraitLocalization>

	<TraitLocalization identifier="dispositionKind" label="Disposition Kind" labelOther="Disposition Kinds">
