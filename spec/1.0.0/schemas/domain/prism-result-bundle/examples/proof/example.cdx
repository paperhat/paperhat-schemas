			retainedComparisonTolerance=0.03
			retainedComparisonValue=0.01
			subjectIndex=0
			tokenSelectorIdentity="TokenSet(~brand)/Token(~brandAccent)"
		/>
	</ProofTargetResult>

	<RenderedProofArtifactReference
		artifactKind="RenderedProofPreview"
		artifactLocator=urn:paperhat:example:artifact:proof:web-srgb-proof-preview
		proofTargetIdentifier="web-srgb-proof"
		renderingIntent=$Perceptual
		sourceOperationIdentifier="RenderProofPreview"
	/>
</Proof>
