<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="A named, ordered sequence of steps that accomplishes a specific operational task — a release procedure, deployment workflow, or setup guide."
	id=paperhat:domain:procedure
	namespace="procedure"
	title="Procedure Schema"
	version="1.0.0"
	versionScheme=$SemanticVersion
>
	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:procedure:Procedure
			name="Procedure"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="name" />

				<AllowsTrait name="procedureKind" />

				<AllowsTrait name="procedureStatus" />
			</TraitRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:procedure:trait:name
			name="name"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:procedure:trait:procedureKind
			name="procedureKind"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:procedure:trait:procedureStatus
			name="procedureStatus"
		/>
	</TraitDefinitions>
</Schema>
