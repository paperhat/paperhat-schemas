<Recipe id=urn:paperhat:example:recipe:garden-salad key=~gardenSalad>
	<text:Title>
		Garden Salad
	</text:Title>

	<Ingredients>
		<Ingredient food=urn:food:lettuce />

		<Ingredient food=urn:food:tomato />

		<Ingredient food=urn:food:cucumber />
	</Ingredients>

	<Instructions>
		<Step>
			Wash and chop all vegetables into bite-sized pieces.
		</Step>

		<Step>
			Combine in a large bowl and toss with dressing.
		</Step>
	</Instructions>
</Recipe>
