<RelationType
	id=urn:paperhat:relation-type:project
	name="Project"
>
	<Attribute
		id=urn:paperhat:relation-type:project:attribute:name
		name="name"
		valueType=$Text
		required=true
	/>
	<Attribute
		id=urn:paperhat:relation-type:project:attribute:budget
		name="budget"
		valueType=$Number
		required=true
	/>
</RelationType>
