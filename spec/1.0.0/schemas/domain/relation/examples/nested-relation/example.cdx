<RelationType id=urn:paperhat:relation-type:project name="Project">
	<Attribute
		id=urn:paperhat:relation-type:project:attribute:name
		name="name"
		required=true
		valueType=$Text
	/>

	<Attribute
		id=urn:paperhat:relation-type:project:attribute:budget
		name="budget"
		required=true
		valueType=$Number
	/>
</RelationType>
