<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="A versioned artifact snapshot of a product — a specific release such as v2.3.1 of a software system, carrying version, lifecycle status, and a back-reference to the product it belongs to."
	id=paperhat:domain:release
	namespace="release"
	title="Release Schema"
	version="1.0.0"
	versionScheme=$Semver
>
	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:release:Release
			name="Release"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<TraitRules>
				<RequiresTrait name="version" />

				<AllowsTrait name="releaseKind" />

				<AllowsTrait name="releaseStatus" />

				<AllowsTrait name="releaseDate" />

				<AllowsTrait name="product" />
			</TraitRules>
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:release:trait:version
			name="version"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:release:trait:releaseKind
			name="releaseKind"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:release:trait:releaseStatus
			name="releaseStatus"
		/>

		<TraitDefinition
			defaultValueType=$Date
			id=paperhat:domain:release:trait:releaseDate
			name="releaseDate"
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:release:trait:product
			isReferenceTrait=true
			name="product"
		/>
	</TraitDefinitions>
</Schema>
