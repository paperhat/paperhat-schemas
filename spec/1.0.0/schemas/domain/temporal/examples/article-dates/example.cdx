<TemporalAnnotations>
	<Date key=~published value=date(15 march 2024) format=$Long language=language-tag("en") />
	<Date key=~updated value=date(2 november 2024) format=$Short />
	<YearMonth key=~archiveMonth value=year-month(march 2024) format=$Long language=language-tag("en") />
</TemporalAnnotations>
