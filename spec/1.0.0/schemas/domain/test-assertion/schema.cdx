<Schema
	authoringMode=$SimplifiedMode
	compatibilityClass=$Initial
	description="Test assertions for verifying conformance to specification requirements. Links assertions to requirements by IRI reference, with status tracking, test method classification, preconditions, and expected outcomes."
	id=paperhat:domain:test-assertion
	namespace="test"
	title="Test Assertion Schema"
	version="1.0.0"
	versionScheme=$Semver
>
	<SchemaImports>
		<SchemaImport namespace="desc" reference=urn:cdx:sha256:a4b26166df726e9c0125b331fc41555d0fd1b455fb93da24b592ba5f2293c641 />

		<SchemaImport namespace="text" reference=urn:cdx:sha256:41dd6cc084a5a5d124cdfbfa17b4e4e640a864c52b13eb624b482c0f3d7f62df />
	</SchemaImports>

	<ConceptDefinitions>
		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustBeEntity
			id=paperhat:domain:test-assertion:TestAssertion
			name="TestAssertion"
		>
			<TraitRules>
				<RequiresTrait name="key" />

				<RequiresTrait name="requirementRef" />

				<AllowsTrait name="title" />

				<AllowsTrait name="status">
					<AllowedValues>
						<EnumeratedConstraint set="AssertionStatus" />
					</AllowedValues>
				</AllowsTrait>

				<AllowsTrait name="testMethod">
					<AllowedValues>
						<EnumeratedConstraint set="TestMethod" />
					</AllowedValues>
				</AllowsTrait>

				<AllowsTrait name="severity">
					<AllowedValues>
						<EnumeratedConstraint set="AssertionSeverity" />
					</AllowedValues>
				</AllowsTrait>

				<AllowsTrait name="label" />
			</TraitRules>

			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<AllowsChildConcept conceptSelector="Precondition" />

				<AllowsChildConcept conceptSelector="ExpectedOutcome" />

				<AllowsChildConcept conceptSelector="TestProcedure" />

				<AllowsChildConcept conceptSelector="desc:Description" />

				<AllowsChildConcept conceptSelector="text:Paragraph" />
			</ChildRules>
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:test-assertion:Precondition
			name="Precondition"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="text:Paragraph" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:test-assertion:ExpectedOutcome
			name="ExpectedOutcome"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="text:Paragraph" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:test-assertion:TestProcedure
			name="TestProcedure"
		>
			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="text:Paragraph" min=1 />
			</ChildRules>

			<CollectionRules allowsDuplicates=true ordering=$Ordered />
		</ConceptDefinition>

		<ConceptDefinition
			conceptKind=$Semantic
			entityEligibility=$MustNotBeEntity
			id=paperhat:domain:test-assertion:TestSuite
			name="TestSuite"
		>
			<TraitRules>
				<RequiresTrait name="key" />

				<RequiresTrait name="title" />

				<AllowsTrait name="label" />
			</TraitRules>

			<ContentRules>
				<ForbidsContent />
			</ContentRules>

			<ChildRules>
				<RequiresChildConcept conceptSelector="TestAssertion" min=1 />

				<AllowsChildConcept conceptSelector="desc:Description" />

				<AllowsChildConcept conceptSelector="text:Paragraph" />
			</ChildRules>

			<CollectionRules allowsDuplicates=false ordering=$Ordered />
		</ConceptDefinition>
	</ConceptDefinitions>

	<TraitDefinitions>
		<TraitDefinition
			defaultValueType=$LookupToken
			id=paperhat:domain:test-assertion:trait:key
			name="key"
		/>

		<TraitDefinition
			defaultValueType=$Iri
			id=paperhat:domain:test-assertion:trait:requirementRef
			isReferenceTrait=true
			name="requirementRef"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:test-assertion:trait:title
			name="title"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:test-assertion:trait:status
			name="status"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:test-assertion:trait:testMethod
			name="testMethod"
		/>

		<TraitDefinition
			defaultValueType=$EnumeratedToken
			id=paperhat:domain:test-assertion:trait:severity
			name="severity"
		/>

		<TraitDefinition
			defaultValueType=$Text
			id=paperhat:domain:test-assertion:trait:label
			name="label"
		/>
	</TraitDefinitions>

	<EnumeratedValueSets>
		<EnumeratedValueSet id=paperhat:domain:test-assertion:set:AssertionStatus name="AssertionStatus">
			<Member value="Untested" />

			<Member value="Pass" />

			<Member value="Fail" />

			<Member value="NotApplicable" />

			<Member value="Error" />
		</EnumeratedValueSet>

		<EnumeratedValueSet id=paperhat:domain:test-assertion:set:TestMethod name="TestMethod">
			<Member value="Automated" />

			<Member value="Manual" />

			<Member value="Inspection" />

			<Member value="Analysis" />
		</EnumeratedValueSet>

		<EnumeratedValueSet id=paperhat:domain:test-assertion:set:AssertionSeverity name="AssertionSeverity">
			<Member value="Critical" />

			<Member value="Major" />

			<Member value="Minor" />

			<Member value="Informational" />
		</EnumeratedValueSet>
	</EnumeratedValueSets>

	<ConstraintDefinitions>
		<ConstraintDefinition
			id=paperhat:domain:test-assertion:requirement-ref-must-resolve
			title="TestAssertion requirementRef must resolve"
		>
			<Targets>
				<TargetConcept conceptSelector="TestAssertion" />
			</Targets>

			<Rule>
				<ReferenceConstraint type=$ReferenceMustResolve />
			</Rule>
		</ConstraintDefinition>
	</ConstraintDefinitions>
</Schema>
